---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SignupForm from '../components/SignupForm.astro';
---

<Layout title="Nyheder" description="Nyheder, pressemeddelelser og debatindlæg fra PLACEHOLDER NAVN.">
  <Header />
  <main>
    <section class="page-header">
      <div class="container">
        <p class="section-label">Nyheder</p>
        <h1 class="section-title" style="font-size: clamp(32px, 5vw, 48px);">Nyheder og debat</h1>
        <div class="divider-tri"><span></span><span></span><span></span></div>
        <p class="body-text" style="max-width: 580px;">
          Følg med i PLACEHOLDER NAVNs pressemeddelelser, debatindlæg og holdninger til aktuelle sager.
        </p>
      </div>
    </section>

    <section class="nyheder-content">
      <div class="container">
        <div class="nyheder-placeholder">
          <div class="nyheder-placeholder__icon" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
          <p class="body-text" style="text-align: center; max-width: 420px; margin: 0 auto;">
            Der er endnu ingen nyheder at vise. Tilmeld dig vores nyhedsbrev for at få besked, når vi offentliggør nyt.
          </p>
        </div>

        <div class="nyheder-nyhedsbrev">
          <h2 class="nyheder-nyhedsbrev__heading">Hold dig opdateret</h2>
          <div class="nyheder-nyhedsbrev__form">
            <SignupForm variant="nyhedsbrev" />
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-header {
    padding-top: 120px;
    padding-bottom: 40px;
  }

  .nyheder-content {
    padding-bottom: 88px;
  }

  .nyheder-placeholder {
    padding: 64px 32px;
    background: var(--color-bg-alt);
    text-align: center;
    margin-bottom: 64px;
  }

  .nyheder-placeholder__icon {
    display: flex;
    gap: 3px;
    justify-content: center;
    margin-bottom: 24px;
  }

  .nyheder-placeholder__icon span {
    width: 4px;
    height: 24px;
  }

  .nyheder-placeholder__icon span:nth-child(1) { background: var(--color-red); }
  .nyheder-placeholder__icon span:nth-child(2) { background: var(--color-blue); }
  .nyheder-placeholder__icon span:nth-child(3) { background: var(--color-green); }

  .nyheder-nyhedsbrev {
    max-width: 480px;
  }

  .nyheder-nyhedsbrev__heading {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 24px;
  }
</style>
